# Copy to ".env" in this directory (gitignored) and fill in real values.
#   cp .env.example .env
# See docs/ENV_AND_SECRETS_INVENTORY.md for full handoff notes.
# Values here are safe to commit — no secrets.

# --- Core (ISO_AGENT_* via pydantic-settings) ---
ISO_AGENT_PRIMARY_MODE=demo
# ISO_AGENT_KNOWLEDGE_DIR=knowledge

# --- LLM (AWS Bedrock only; Strands BedrockModel) ---
# ISO_AGENT_BEDROCK_MODEL_ID=
# ISO_AGENT_BEDROCK_REGION_NAME=
# ISO_AGENT_BEDROCK_MAX_TOKENS=

# --- AWS (Bedrock; standard AWS env names) ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_REGION=us-west-2

# --- Perplexity (researcher MCP; optional) ---
ISO_AGENT_PERPLEXITY_TRANSPORT=disabled
# PERPLEXITY_API_KEY=

# --- Google Drive (optional; path is standard Google client env) ---
ISO_AGENT_DRIVE_ENABLED=false
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# ISO_AGENT_DRIVE_ALLOWED_FOLDER_IDS=folder_id_one,folder_id_two
# ISO_AGENT_DRIVE_ALLOWED_FILE_IDS=
# ISO_AGENT_DRIVE_MAX_LIST=25

# --- Notion (optional; token has no ISO_ prefix) ---
ISO_AGENT_NOTION_ENABLED=false
# NOTION_TOKEN=
# ISO_AGENT_NOTION_DISCOVERY_ENABLED=false
#   When true: read-only notion_discover_connected_pages (search) without draft parent allowlist.
# ISO_AGENT_NOTION_ALLOWED_PARENT_IDS=
# ISO_AGENT_NOTION_ALLOWED_PAGE_IDS=

# --- Google Chat webhook (optional) ---
# ISO_AGENT_CHAT_WEBHOOK_SECRET=
# ISO_AGENT_CHAT_ALLOW_INSECURE=false
# ISO_AGENT_CHAT_DEDUPE_TTL_SECONDS=300

# --- iso-chat-webhook process ---
# PORT=8080
# UVICORN_LOG_LEVEL=info

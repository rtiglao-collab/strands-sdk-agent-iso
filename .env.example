# Copy to ".env" in this directory (gitignored) and fill in real values.
#   cp .env.example .env
# See docs/ENV_AND_SECRETS_INVENTORY.md for full handoff notes.
# Values here are safe to commit — no secrets.

# --- Core (ISO_AGENT_* via pydantic-settings) ---
ISO_AGENT_PRIMARY_MODE=demo
# ISO_AGENT_KNOWLEDGE_DIR=knowledge
# Optional pip (not env): pip install -e ".[excel]" for .xlsx in python_repl — see requirements-excel.txt

# --- LLM (Amazon Bedrock only — see .cursor/rules/llm-bedrock-only.mdc) ---
# ISO_AGENT_BEDROCK_MODEL_ID=
# ISO_AGENT_BEDROCK_REGION_NAME=
# ISO_AGENT_BEDROCK_MAX_TOKENS=

# --- AWS (Bedrock; standard AWS env names) ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_REGION=us-west-2

# --- Perplexity (researcher MCP; optional) ---
ISO_AGENT_PERPLEXITY_TRANSPORT=disabled
# PERPLEXITY_API_KEY=

# --- Google Workspace MCP (required for Google Drive/Sheets/Docs/etc. on Neuuf; user OAuth via npx google-workspace-mcp setup) ---
# pydantic default for other entrypoints is disabled; iso-neuuf-coordinator sets TRANSPORT=stdio
# and DEBUG=true when these are unset (local testing). Override here or in the shell as needed.
# ISO_AGENT_GOOGLE_WORKSPACE_MCP_TRANSPORT=disabled
#   disabled | stdio — merges google_workspace_mcp_* tools on coordinator
#   Google file access is google_workspace_mcp_* only (no REST drive_* on coordinator).
# ISO_AGENT_GOOGLE_WORKSPACE_MCP_SERVE_READ_ONLY=true
#   When stdio: default true appends --read-only to serve (set false only if you need MCP writes)
# ISO_AGENT_GOOGLE_WORKSPACE_MCP_DEBUG=false
#   false / 0 / no — disable Strands/MCP DEBUG on stderr (iso-neuuf-coordinator; default-on if unset)

# --- Notion (optional; coordinator uses hosted MCP + OAuth) ---
# ISO_AGENT_NOTION_ENABLED=false
# ISO_AGENT_NOTION_TRANSPORT=hybrid
#   hybrid (default) | mcp_primary | rest_only — rest_only disables coordinator notion_* tools.
# ISO_AGENT_NOTION_MCP_URL=https://mcp.notion.com/mcp
# ISO_AGENT_NOTION_MCP_REDIRECT_URI=http://127.0.0.1:8765/callback
# Run once: iso-notion-mcp-login  (writes mcp_oauth.json; see docs/NOTION_MCP.md)
# ISO_AGENT_NOTION_DISCOVERY_ENABLED=false
#   Defaults true: notion_discover_connected_pages is registered. Set false to hide it only.
# ISO_AGENT_NOTION_ALLOWED_PARENT_IDS=
# ISO_AGENT_NOTION_ALLOWED_PAGE_IDS=
# NOTION_TOKEN=  # ad-hoc REST only (tests/manual_notion_page_inspect.py), not coordinator tools

# --- Google Chat webhook (optional) ---
# ISO_AGENT_CHAT_WEBHOOK_SECRET=
# ISO_AGENT_CHAT_ALLOW_INSECURE=false
# ISO_AGENT_CHAT_DEDUPE_TTL_SECONDS=300

# --- iso-chat-webhook process ---
# PORT=8080
# UVICORN_LOG_LEVEL=info
